{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://svgap.dev/schemas/trace-v1.json",
  "title": "SV-Gap digital observation trace",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "trace_id", "candidate_digest", "observer", "signals", "samples"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "trace_id": {"type": "string", "minLength": 1},
    "candidate_digest": {"type": "string", "minLength": 1},
    "observer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "sampling"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "sampling": {"type": "string", "minLength": 1}
      }
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cycle", "clock", "values"],
        "properties": {
          "cycle": {"type": "integer", "minimum": 0},
          "clock": {"type": "string", "minLength": 1},
          "values": {
            "type": "object",
            "additionalProperties": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "provenance": {"type": "object"}
  }
}
