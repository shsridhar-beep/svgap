{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://svgap.dev/schemas/adjudication-v1.json",
  "title": "SV-Gap generic digital adjudication result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "candidate_id", "candidate_digest", "rule_id",
    "semantics", "instrumenter", "observer", "verdict", "seed_budget",
    "seeds_completed", "golden_trace_digest", "calibration", "diagnostics",
    "generated_at"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "candidate_id": {"type": "string", "minLength": 1},
    "candidate_digest": {"type": "string", "minLength": 1},
    "rule_id": {"type": "string", "minLength": 1},
    "semantics": {"$ref": "#/$defs/component"},
    "instrumenter": {"$ref": "#/$defs/instrumenter"},
    "observer": {"$ref": "#/$defs/component"},
    "verdict": {"enum": ["hazard_demonstrated", "no_divergence_observed", "inconclusive"]},
    "seed_budget": {"type": "integer", "minimum": 0},
    "seeds_completed": {"type": "integer", "minimum": 0},
    "golden_trace_digest": {"type": "string", "minLength": 1},
    "reproducer": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["seed", "observed_trace_digest", "first_divergence"],
      "properties": {
        "seed": {"type": "integer", "minimum": 0},
        "observed_trace_digest": {"type": "string", "minLength": 1},
        "first_divergence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cycle", "signal", "golden", "observed"],
          "properties": {
            "cycle": {"type": "integer", "minimum": 0},
            "signal": {"type": "string", "minLength": 1},
            "golden": {"type": "string"},
            "observed": {"type": "string"}
          }
        }
      }
    },
    "calibration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "suite_digest"],
      "properties": {
        "status": {"enum": ["pass", "fail", "not_run"]},
        "suite_digest": {"type": "string"}
      }
    },
    "diagnostics": {"type": "array", "items": {"type": "string"}},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "instrumenter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "mode"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "mode": {"enum": ["mock_prerecorded", "unavailable"]}
      }
    }
  }
}
