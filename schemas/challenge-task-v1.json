{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://svgap.dev/schemas/challenge-task-v1.json",
  "title": "SV-Gap frontier-model challenge task",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "challenge_id", "task_id", "track", "title"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "challenge_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "track": {"enum": ["generation", "diagnosis", "repair"]},
    "title": {"type": "string", "minLength": 1},
    "target_rule": {"type": "string", "minLength": 1},
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question_id", "prompt", "expected_status"],
        "properties": {
          "question_id": {"type": "string", "minLength": 1},
          "prompt": {"type": "string", "minLength": 1},
          "expected_status": {"enum": ["answered", "failed", "unanswered"]}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"track": {"const": "diagnosis"}}},
      "then": {"required": ["questions"], "not": {"required": ["target_rule"]}}
    },
    {
      "if": {"properties": {"track": {"const": "generation"}}},
      "then": {"not": {"anyOf": [{"required": ["questions"]}, {"required": ["target_rule"]}]}}
    },
    {
      "if": {"properties": {"track": {"const": "repair"}}},
      "then": {"required": ["target_rule"], "not": {"required": ["questions"]}}
    }
  ]
}
